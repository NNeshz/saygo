{
  "extends": "@saygo/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@saygo/auth": ["../../packages/auth/src/index.ts"],
      "@saygo/auth/*": ["../../packages/auth/src/*"],
      "@saygo/ui": ["../../packages/ui/src/index.ts"],
      "@saygo/ui/*": ["../../packages/ui/src/*"],
      "@saygo/api": ["../../packages/api/src/index.ts"],
      "@saygo/api/*": ["../../packages/api/src/*"],
      "@saygo/database": ["../../packages/database/src/index.ts"],
      "@saygo/database/*": ["../../packages/database/src/*"]
    }
  },
  "include": ["app", "modules", "utils", "next-env.d.ts", "*.ts", "*.tsx"],
  "exclude": ["node_modules"]
}
